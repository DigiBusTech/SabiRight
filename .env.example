# Database Connection (PostgreSQL via Supabase)
DATABASE_URL=postgresql://your-user:your-password@your-host:5432/your-db

# Client-side Supabase Config
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase Config
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini AI API Key
GEMINI_API_KEY=your-gemini-api-key

# Optional: Paystack / Flutterwave Keys
PAYSTACK_SECRET_KEY=your-paystack-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-key

# Production Port
PORT=5000
NODE_ENV=production
